{
  "name": "a2a-overture",
  "version": "0.2.0",
  "description": "The opening act for your A2A agents — discover, test, and certify A2A protocol compliance",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "overture": "dist/index.js"
  },
  "files": [
    "dist/",
    "action/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kapil8811/a2a-overture.git"
  },
  "homepage": "https://github.com/kapil8811/a2a-overture#readme",
  "bugs": {
    "url": "https://github.com/kapil8811/a2a-overture/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "mock": "node dist/index.js mock",
    "web": "node dist/index.js web",
    "registry": "node dist/index.js registry serve",
    "demo": "node dist/index.js mock & node dist/index.js web",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "a2a",
    "agent2agent",
    "ai-agents",
    "testing",
    "certification",
    "protocol",
