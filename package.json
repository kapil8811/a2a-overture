    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ajv": "^8.17.1",
    "ora": "^8.1.0",
    "cli-table3": "^0.6.5",
    "eventsource": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.2",
    "@types/eventsource": "^1.1.15"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
